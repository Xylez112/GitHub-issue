# DeepSeek API Key (required for LLM analysis)
# Get it from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# GitHub Personal Access Token (optional, increases API rate limit from 60 → 5000 req/hr)
# Get it from: https://github.com/settings/tokens
# No scopes needed for public repos
GITHUB_TOKEN=

# ChromaDB persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_data
